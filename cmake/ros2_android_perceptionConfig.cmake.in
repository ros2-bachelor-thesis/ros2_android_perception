@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies
find_dependency(Eigen3 REQUIRED)
find_dependency(ncnn REQUIRED)
find_dependency(OpenCV REQUIRED COMPONENTS core imgproc)

# Include targets
include("${CMAKE_CURRENT_LIST_DIR}/ros2_android_perceptionTargets.cmake")

check_required_components(ros2_android_perception)
